# Copy this file to configs/monitor_settings.env. Never commit the copied file.
# The non-hidden filename works on environments that reject dot-prefixed files.

# Camera and model
RTSP_URL=rtsp://user:password@10.34.23.152:554/live.sdp
MODEL_PATH=models/best.pt
SITE_NAME=Plant-A
CAMERA_NAME=Chimney-01

# Inference
DEVICE=auto
IMGSZ=640
CONF_THRESHOLD=0.35
IOU_THRESHOLD=0.50
MIN_SMOKE_AREA_RATIO=0.005
SAMPLE_INTERVAL_SECONDS=1.0
POSITIVE_FRAMES_TO_ALARM=5
NEGATIVE_FRAMES_TO_CLEAR=30
ALERT_REPEAT_SECONDS=1800
RECONNECT_SECONDS=5
# x1,y1,x2,y2 in original frame coordinates. Leave blank for full frame.
ROI_XYXY=

# Runtime output
RUNTIME_DIR=data/runtime
# INFO prints each smoke detection to the CLI and data/runtime/logs/monitor.log.
LOG_LEVEL=INFO
# Shadow mode evaluates and records alarms but never sends email.
SHADOW_MODE=false
# 0 disables no-smoke JSONL summaries. Smoke detections and alarm events are still recorded.
NO_SMOKE_LOG_INTERVAL_SECONDS=0
# Display annotated frames as a browser video preview; no live JPG is written.
ALLOW_LIVE_STREAMING=false
LIVE_STREAM_HOST=127.0.0.1
LIVE_STREAM_PORT=8765
# Smoke detections are retained outside the training dataset for review.
SAVE_ALERT_SNAPSHOTS=true
ALERT_SNAPSHOTS_DIR=data/runtime/alerts
ALERT_SNAPSHOT_INTERVAL_SECONDS=1.0
JPEG_QUALITY=90

# SMTP. Use an internal SMTP relay reachable from the isolated camera PC.
# Direct public-mail SMTP will not work in a fully air-gapped network.
SMTP_HOST=mail-relay.internal
SMTP_PORT=25
SMTP_SECURITY=none
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM=smoke-monitor@internal.example
ALERT_TO=environment-team@internal.example
MAIL_ON_RECOVERY=true
SMTP_TIMEOUT_SECONDS=20

# Legacy name accepted for migration only; use SAVE_ALERT_SNAPSHOTS above.
# SAVE_POSITIVE_SNAPSHOTS=true
